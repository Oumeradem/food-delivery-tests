{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist"
  },
  "include": [
    "features/**/*.ts",
    "hooks/**/*.ts",
    "pages/**/*.ts",
    "steps/**/*.ts",
    "utilities/**/*.ts",
    "globalPagesSetup.ts"
  ]
}